# Server
PORT=3001
NODE_ENV=development
DATA_FILE_PATH=data/notes.json

# Storage provider: "local-json" for local development, "azure-table" for Azure Table Storage.
STORAGE_PROVIDER=local-json

# Azure Table Storage settings. Use a table-level SAS URL in Azure App Settings.
# Example shape: https://<account>.table.core.windows.net/StudyNotes?<sas-token>
AZURE_TABLES_TABLE_URL=
AZURE_TABLES_PARTITION_KEY=notes

# AI provider: "mock" for local development, "azure-openai" for real Azure AI.
AI_PROVIDER=mock

# Azure OpenAI settings. Keep real values in .env.local or Azure App Settings.
AZURE_OPENAI_ENDPOINT= 
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=
